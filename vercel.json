{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "angular",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/edustay-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://edustay-backend.fly.dev/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://edustay-backend.fly.dev/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
